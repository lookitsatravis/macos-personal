#!/bin/bash

WORLD_NAME=HouseOfYeet # OdinsBeardCrust
command=status

if [ "$VALHEIM_WORLDNAME" = "" ] ; then
    WORLD_NAME=$WORLD_NAME
else
    WORLD_NAME=$VALHEIM_WORLDNAME
fi

SERVER_IP=137.184.21.52
SERVER_PORT=2459 # 2456
SERVER_USER=root
WORLD_PASSWORD=fuccboi
BACKUPS_DIR="/Users/travisvignon/Google Drive/My Drive/Valheim/Backups/Worlds/${WORLD_NAME}"
REMOTE_BACKUPS_DIR="/home/steam/backups/${WORLD_NAME}/"
REMOTE_SCRIPT_DIR=/opt/Dedicated_Valheim_Server_Script
REMOTE_SCRIPT_PATH=./njordmenu.sh

function send_ssh_command() {
    if [ "${command}" = "" ] ; then  help ; fi
    if [ "$1" = "" ] ; then echo "Running \"${command}\" command on server ${SERVER_IP}..." ; fi
    ssh "${SERVER_USER}@${SERVER_IP}" -tq "cd ${REMOTE_SCRIPT_DIR} && yes | sudo VALHEIM_WORLDNAME=${WORLD_NAME} ${REMOTE_SCRIPT_PATH} ${command}"
}

NOCOLOR='\033[0m'
RED='\033[0;31m'
GREEN='\033[0;32m'
ORANGE='\033[0;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
LIGHTRED='\033[1;31m'
LIGHTGREEN='\033[1;32m'
YELLOW='\033[1;33m'
WHITE='\033[1;37m'
clear='\e[0m'
##
# Color Functions
##
ColorRed(){ 
    echo -ne $RED$1$NOCOLOR 
}
ColorGreen(){
    echo -ne $GREEN$1$NOCOLOR
}
ColorOrange(){
	echo -ne $ORANGE$1$NOCOLOR
}
ColorBlue(){
	echo -ne $BLUE$1$NOCOLOR
}
ColorPurple(){
	echo -ne $PURPLE$1$NOCOLOR
}
ColorCyan(){
	echo -ne $CYAN$1$NOCOLOR
}
ColorLightRed(){
	echo -ne $LIGHTRED$1$NOCOLOR
}
ColorLightGreen(){
	echo -ne $LIGHTGREEN$1$NOCOLOR
}
ColorYellow(){
	echo -ne $LIGHTYELLOW$1$NOCOLOR
}
ColorWhite(){
	echo -ne $WHITE$1$NOCOLOR
}

function trim() {
    local var="$*"
    # remove leading whitespace characters
    var="${var#"${var%%[![:space:]]*}"}"
    # remove trailing whitespace characters
    var="${var%"${var##*[![:space:]]}"}"   
    printf '%s' "$var"
}

