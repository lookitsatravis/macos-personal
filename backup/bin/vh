function connect_to_valheim_server() {
    ssh "${SERVER_USER}@${SERVER_IP}"
}

function start_valheim_server_menu() {
    ssh "${SERVER_USER}@${SERVER_IP}" -t "cd ${REMOTE_SCRIPT_DIR} && VALHEIM_WORLDNAME=${WORLD_NAME} ${REMOTE_SCRIPT_PATH}"
}

function start_valheim_server() {
    command=start
    send_ssh_command
}

function stop_valheim_server() {
    command=stop
    send_ssh_command

    # To permenantly disable: sudo systemctl disable valheimserver_OdinsBeardCrust.service
}

function restart_valheim_server() {
    command=restart
    send_ssh_command
}

function check_apply_server_updates_beta() {
    command=update
    send_ssh_command
}

function backup_world_data() {
    command=backup
    send_ssh_command
    rsync -azP "${SERVER_USER}@${SERVER_IP}:${REMOTE_BACKUPS_DIR}" "${BACKUPS_DIR}"
}

function display_valheim_server_status() {
    command=status
    send_ssh_command
}

function tail_valheim_server_logs() {
    today=$(date +"%Y-%m-%d")
    ssh "${SERVER_USER}@${SERVER_IP}" -t "journalctl -u valheimserver_${WORLD_NAME}.service --since \"${today} 00:00:00\" --no-pager -f"
}

function show_ip() {
    echo ${SERVER_IP}:${SERVER_PORT}
}

if [ $# = 0 ]; then
    help
else
    case "$1" in
    connect) connect_to_valheim_server ;;
    menu)    start_valheim_server_menu ;;
    start)   start_valheim_server ;;
    stop)    stop_valheim_server  ;;
    restart) restart_valheim_server ;;
    update)  check_apply_server_updates_beta ;;
    backup)  backup_world_data ;;
    status)  display_valheim_server_status ;;
    logs)    tail_valheim_server_logs ;;
    ip)      show_ip ;;
    *)
        help
        ;;
    esac
fi 