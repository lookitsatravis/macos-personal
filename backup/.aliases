alias glregistry="docker login registry.appdat.jsc.nasa.gov -u travis.vignon -p $MRI_GITLAB_PAT"
alias tg="terragrunt"
alias tggraph="tg graph --draw-cycles | dot -Tpng > graph.png && open graph.png"
alias tgviz="pyenv global 3.9 && blast-radius --serve . --port 5001"
